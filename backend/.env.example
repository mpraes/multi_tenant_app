# ════════════════════════════════════════════════════════════════════════════
#  .env.example — copy to .env and fill in values for local development
#  In production: inject these as Docker secrets or Kubernetes env vars.
#  NEVER commit the real .env to version control.
# ════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=development          # development | staging | production
LOG_LEVEL=INFO               # DEBUG | INFO | WARNING | ERROR
SECRET_KEY=change-me-in-production

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Set LLM_PROVIDER to the provider you want globally.
# Individual tenants can override this in their customers/<slug>/config.py
LLM_PROVIDER=openai          # openai | azure_openai | ollama

# OpenAI (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini     # gpt-4o-mini (cheap) | gpt-4o (smarter)

# Azure OpenAI (used when LLM_PROVIDER=azure_openai)
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_ENDPOINT=https://<your-resource>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-02-01

# Ollama — local/offline LLM (used when LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── Database ──────────────────────────────────────────────────────────────────
# SQLite for local dev (zero setup). Switch to PostgreSQL for production.
DATABASE_URL=sqlite+aiosqlite:///./dev.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/chatbot

# ── Cache / Redis ─────────────────────────────────────────────────────────────
# Optional — used for session caching. Can be left empty in dev.
REDIS_URL=redis://localhost:6379/0

# ── Channels — fill in only the ones you use ─────────────────────────────────

# Telegram
TELEGRAM_BOT_TOKEN=

# Slack
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=

# WhatsApp via Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# ── RAG ───────────────────────────────────────────────────────────────────────
RAG_ENABLED=false
RAG_VECTOR_STORE=chromadb    # chromadb | pgvector | pinecone
RAG_CHROMA_PATH=./chroma_data

